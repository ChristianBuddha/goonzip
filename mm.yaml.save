# ===============================
# AMCL (사용 안 해도 문제 없음)
# ===============================
amcl:
  ros__parameters:
    use_sim_time: false

# ===============================
# BT Navigator
# ===============================
bt_navigator:
  ros__parameters:
    use_sim_time: false
    global_frame: map
    robot_base_frame: base_footprint
    odom_topic: /odom
    bt_loop_duration: 10
    default_server_timeout: 20
    enable_groot_monitoring: false

# ===============================
# Planner Server (Global Planner)
# ===============================
planner_server:
  ros__parameters:
    use_sim_time: false
    expected_planner_frequency: 5.0
    planner_plugins: ["GridBased"]

    GridBased:
      plugin: "nav2_navfn_planner/NavfnPlannerplugin: "nav2_navfn_planner::NavfnPlanner""
      tolerance: 0.5
      use_astar: true
      allow_unknown: true

# ===============================
# Controller Server (⭐ 핵심)
# ===============================
controller_server:
  ros__parameters:
    use_sim_time: false
    controller_frequency: 10.0        # ⭐ 20Hz 금지
    min_x_velocity_threshold: 0.001
    min_y_velocity_threshold: 0.001
    min_theta_velocity_threshold: 0.001
    failure_tolerance: 0.3

    controller_plugins: ["FollowPath"]

    FollowPath:
      plugin: "dwb_core::DWBLocalPlanner"

      debug_trajectory_details: false

      # 🔻 연산량 줄인 샘플 수
      vx_samples: 10
      vy_samples: 5
      vtheta_samples: 10
      sim_time: 1.0

      # 속도 제한 (실로봇 안전)
      max_vel_x: 0.3
      min_vel_x: 0.0
      max_vel_theta: 0.6
      min_speed_theta: 0.1

      acc_lim_x: 0.8
      acc_lim_theta: 1.5

      # ⭐ Jazzy에서 안정적인 최소 critic 세트
      critics:
        - BaseObstacle
        - GoalAlign
        - PathAlign

      Obstacle.scale: 0.02
      GoalAlign.scale: 16.0
      PathAlign.scale: 16.0

# ===============================
# Local Costmap
# ===============================
local_costmap:
  local_costmap:
    ros__parameters:
      use_sim_time: false
      global_frame: odom
      robot_base_frame: base_footprint
      rolling_window: true
      width: 3
      height: 3
      resolution: 0.05
      update_frequency: 5.0
      publish_frequency: 5.0
      transform_tolerance: 0.3

      footprint: "[[0.25, 0.2], [0.25, -0.2], [-0.25, -0.2], [-0.25, 0.2]]"

      plugins: ["obstacle_layer", "inflation_layer"]

      obstacle_layer:
        plugin: "nav2_costmap_2d::ObstacleLayer"
        observation_sources: scan
        scan:
          topic: /scan
          max_obstacle_height: 2.0
          clearing: true
          marking: true
          data_type: "LaserScan"

      inflation_layer:
        plugin: "nav2_costmap_2d::InflationLayer"
        inflation_radius: 0.5
        cost_scaling_factor: 3.0

# ===============================
# Global Costmap
# ===============================
global_costmap:
  global_costmap:
    ros__parameters:
      use_sim_time: false
      global_frame: map
      robot_base_frame: base_footprint
      resolution: 0.05
      update_frequency: 2.0
      publish_frequency: 2.0
      transform_tolerance: 0.3

      footprint: "[[0.25, 0.2], [0.25, -0.2], [-0.25, -0.2], [-0.25, 0.2]]"

      plugins: ["static_layer", "inflation_layer"]

      static_layer:
        plugin: "nav2_costmap_2d::StaticLayer"

      inflation_layer:
        plugin: "nav2_costmap_2d::InflationLayer"
        inflation_radius: 0.6
        cost_scaling_factor: 3.0

# ===============================
# Waypoint Follower
# ===============================
waypoint_follower:
  ros__parameters:
    use_sim_time: false
    loop_rate: 5
    stop_on_failure: false

# ===============================
# Velocity Smoother
# ===============================
velocity_smoother:
  ros__parameters:
    use_sim_time: false
    smoothing_frequency: 10.0
    max_velocity: [0.4, 0.0, 0.6]
    min_velocity: [0.0, 0.0, -0.6]
    max_accel: [0.8, 0.0, 1.5]
    max_decel: [-0.8, 0.0, -1.5]

# ===============================
# Collision Monitor (❌ 비활성화)
# ===============================
collision_monitor:
  ros__parameters:
    enabled: false
